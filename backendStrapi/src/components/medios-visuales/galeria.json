{
  "collectionName": "components_galerias",
  "info": {
    "displayName": "Galería",
    "icon": "grid",
    "description": "Galería de imágenes con diseño configurable"
  },
  "options": {},
  "attributes": {
    "titulo": {
      "type": "string",
      "required": false,
      "default": "Este es un titulo de ejemplo"
    },
    "descripcion": {
      "type": "text",
      "maxLength": 500,
      "required": false,
      "default": "Descripcion de galeria de ejemplo"
    },
    "cartas": {
      "type": "component",
      "repeatable": true,
      "component": "medios-visuales.imagen-galeria",
      "required": true,
      "min": 1,
      "max": 20
    },
    "columnas": {
      "type": "enumeration",
      "enum": ["2", "3", "4"],
      "default": "3",
      "required": false
    },
    "mostrarTitulos": {
      "type": "boolean",
      "default": true,
      "required": false
    },
    "efecto": {
      "type": "boolean",
      "default": true,
      "required": false
    }
  }
}
