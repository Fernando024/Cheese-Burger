{
  "collectionName": "components_comercial_planes-precios",
  "info": {
    "displayName": "Planes y precio",
    "description": "Tarjeta con un precio único y fijo"
  },
  "attributes": {
    "titulo": {
      "type": "string",
      "default": "Título de ejemplo",
      "maxLength": 80,
      "required": false
    },
    "subtitulo": {
      "type": "string",
      "default": "Subtítulo de ejemplo",
      "maxLength": 120,
      "required": false
    },
    "descripcion": {
      "type": "richtext",
      "required": false,
      "default": "Esta es una descripción de ejemplo para la tarjeta de precio."
    },
    "precio": {
      "type": "decimal",
      "required": false,
      "default": 0
    },
    "moneda": {
      "type": "string",
      "default": "MXN",
      "maxLength": 10,
      "required": false
    },
    "nota_precio": {
      "type": "string",
      "default": "Nota sobre el precio (ej. IVA incluido)",
      "maxLength": 60,
      "required": false
    },
    "insignia": {
      "type": "string",
      "default": "Oferta",
      "maxLength": 50,
      "required": false
    },
    "logo": {
      "type": "media",
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "caracteristicas": {
      "type": "component",
      "component": "comercial.caracteristica",
      "repeatable": true,
      "required": false,
      "min": 1,
      "max": 15
    },
    "boton": {
      "type": "component",
      "component": "independientes.boton",
      "repeatable": false
    }
  }
}
